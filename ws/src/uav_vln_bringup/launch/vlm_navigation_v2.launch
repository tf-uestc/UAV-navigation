<launch>
  <!--
  vlm_navigation_v2.launch - VLM 视觉语言导航 v2
  (模块化架构: MAVROS + setpoint_bridge + detector_node)

  v2 vs v1 差异:
    v1: 单一大节点 vlm_navigation.py (VLM推理 + 深度投影 + 目标发布 耦合在一起)
    v2: 拆分为 detector_node (独立目标检测) + 后续规划/控制模块
         - detector_node 支持通过 detector_class 参数切换不同检测器后端
         - 默认使用 dummy_detector.DummyDetector (返回固定检测框，无 VLM)
         - 生产环境切换为 qwen_vl_grounding.QwenVLGroundingDetector

  使用方法:
    参数说明:
      - detector_class="dummy_detector.DummyDetector"    → 离线仿真测试 (无需 API)
      - detector_class="qwen_vl_grounding.QwenVLGroundingDetector" → 生产环境 (需要 VLM API)

    1. 先在终端启动 PX4 SITL + Gazebo:
        cd ~/毕业设计 && ./scripts_start_px4_sitl_gazebo.sh
        (等待 PX4 完全启动, Gazebo 界面出现)

    2. 然后在新终端启动此 launch:
        cd ~/毕业设计/ws && source devel/setup.bash && roslaunch uav_vln_bringup vlm_navigation_v2.launch

    3. 切换检测器 (启动时传参):
        roslaunch uav_vln_bringup vlm_navigation_v2.launch detector_class:=qwen_vl_grounding.QwenVLGroundingDetector

    4. (可选) 启动后通过 rqt_image_view 查看调试图像:
         rosrun rqt_image_view rqt_image_view /uav/target_debug
  -->

  <!-- ===== 启动参数 ===== -->
  <arg name="detector_class" default="dummy_detector.DummyDetector" />

  <!-- ===== MAVROS (飞控桥接) ===== -->
  <include file="$(find uav_vln_bringup)/launch/mavros_px4_sitl.launch">
    <arg name="fcu_url" value="udp://:14540@127.0.0.1:14557" />
  </include>

  <!-- ===== setpoint_bridge (飞控接口中间层) ===== -->
  <node pkg="uav_vln_bringup" type="setpoint_bridge.py" name="setpoint_bridge" output="screen">
    <param name="setpoint_rate" value="20" />
    <param name="takeoff_alt" value="2.0" />
    <param name="goal_timeout" value="2.0" />
    <param name="approach_dist" value="1.0" />
  </node>

  <!-- ===== detector_node (VLM 目标检测, 替代旧版 vlm_navigation.py) ===== -->
  <!--
    detector_class 参数支持:
      - "dummy_detector.DummyDetector"           : 返回固定检测框, 无需 VLM API (默认)
      - "qwen_vl_grounding.QwenVLGroundingDetector": 使用 Qwen-VL 模型进行视觉定位

    QwenVLGroundingDetector 构造函数签名:
      QwenVLGroundingDetector(api_key, model, timeout, ...)
    可通过 detector_args YAML 字符串传入额外参数 (如 timeout)
  -->
  <node pkg="uav_vln_bringup" type="detector_node.py" name="detector_node" output="screen"
        respawn="true">

    <!-- 检测器后端 (importlib 动态加载) -->
    <param name="detector_class" value="$(arg detector_class)" />

    <!-- VLM API 配置 (QwenVL 生产模式时需要) -->
    <param name="vlm_api_key" value="$(env VLM_API_KEY)" />
    <param name="vlm_model" value="qwen3.6-plus" />

    <!-- 检测参数 -->
    <param name="confidence_threshold" value="0.3" />
    <param name="trigger_rate" value="0.2" />

    <!-- TF 坐标帧配置
         F3 TF 链条: camera_link_optical → camera_link → base_link → odom → map
         目标帧: map (最终导航目标发布在该帧下)
         相机光学帧: camera_link_optical (深度相机光学坐标系) -->
    <param name="target_frame" value="map" />
    <param name="camera_optical_frame" value="camera_link_optical" />
  </node>

</launch>
