<launch>
  <arg name="fcu_url" default="udp://:14540@127.0.0.1:14557" />

  <include file="$(find uav_vln_bringup)/launch/mavros_px4_sitl.launch">
    <arg name="fcu_url" value="$(arg fcu_url)" />
  </include>

  <node pkg="uav_vln_bringup" type="takeoff_land.py" name="takeoff_land" output="screen">
    <param name="takeoff_alt" value="2.0" />
    <param name="hover_time" value="10.0" />
    <param name="setpoint_rate" value="20.0" />
  </node>
</launch>
