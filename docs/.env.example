# =============================================================================
# Environment Variables for UAV VLN (Visual Language Navigation) Project
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp docs/.env.example .env
#
# Load before launching:
#   source .env
#   roslaunch uav_vln_bringup vlm_navigation.launch
#
# Or export directly:
#   export VLM_API_KEY=sk-xxx
# =============================================================================

# ---------------------------------------------------------------------------
# VLM API Key (REQUIRED)
# ---------------------------------------------------------------------------
# Provider: DashScope (Alibaba Cloud / Aliyun)
# Endpoint: OpenAI-compatible API
# Key format: sk-xxxx (e.g., sk-abc123def456...)
#
# Where to get it:
#   1. Go to https://dashscope.console.aliyun.com/
#   2. Log in with your Aliyun account
#   3. Navigate to "API Key Management" (API-KEY管理)
#   4. Create a new API key
#   5. Copy the key (starts with "sk-")
#
# The launch file reads this via $(env VLM_API_KEY), so the variable
# MUST be exported in the shell before starting the ROS node.
#
# IMPORTANT: Never commit a real API key to version control.
#            The .env file is already in .gitignore.
# =============================================================================
export VLM_API_KEY=sk-xxx
